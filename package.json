    "./package.json": "./package.json"
  },
  "files": ["bin.js", "core.js", "core.d.ts", "native", "vendor", "vendor-core", "README.md", "LICENSE-MIT", "LICENSE-APACHE"],
  "scripts": {
    "test": "node --test",
    "build:core": "node scripts/build-core.js",
    "prepack": "node prepare.js"
  },
  "radiochronMcp": {
    "version": "0.2.0",
