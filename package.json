{
  "name": "radiochron",
  "version": "0.3.0",
  "description": "Cross-platform Node.js API for the RadioChron Rust Wi-Fi diagnostics core.",
  "main": "core.js",
  "types": "core.d.ts",
  "exports": {
    ".": { "types": "./core.d.ts", "require": "./core.js", "default": "./core.js" },
    "./core": { "types": "./core.d.ts", "require": "./core.js", "default": "./core.js" },
    "./package.json": "./package.json"
  },
  "files": [
    "core.js",
    "core.d.ts",
    "native/radiochron-node-bridge/Cargo.lock",
    "native/radiochron-node-bridge/Cargo.toml",
    "native/radiochron-node-bridge/src",
    "vendor-core",
    "README.md",
    "LICENSE-MIT"
  ],
  "scripts": {
    "test": "node --test",
    "build:core": "node scripts/build-core.js",
    "verify:package": "node scripts/verify-package.js",
    "prepack": "node prepare.js"
  },
  "radiochronCore": {
    "version": "0.3.0",
    "gitSha": "c5c3b4c30b5395b2c8cbc459f4e85982e5fdbb4a",
    "repository": "https://github.com/sergii-ziborov/radiochron"
  },
  "license": "MIT",
  "author": "Sergii Ziborov",
  "homepage": "https://radiochron.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergii-ziborov/radiochron-js.git"
  },
  "bugs": { "url": "https://github.com/sergii-ziborov/radiochron-js/issues" },
  "keywords": ["wifi", "wlan", "diagnostics", "network", "iot", "nodejs", "windows", "linux", "linux-arm64", "raspberry-pi", "macos", "apple-silicon", "rust"],
  "engines": { "node": ">=18" }
}
